/.build/
.DS_Store
*.xcodeproj
.swiftpm/
.superpowers/

# Packaged .app output from scripts/dev-app.sh and release-app.sh.
/Apps/LutinApp/build/

# Personal Claude Code settings — never check these in.
.claude/

# Release artifacts: produced by `lutin release` / scripts/release-app.sh.
# Ship binaries via GitHub Releases, not git history.
/release/
*.dmg

# Internal planning docs (specs, plans, runbooks, screenshots).
# Kept locally for context but not part of the public repo.
/docs/superpowers/

# Loose icon-source exports at repo root (Icon Composer / iOS-style
# raw PNGs). The vector source-of-truth lives at docs/lutin.icon/
# and the build-needed sizes are in AppIcon.appiconset/; intermediate
# rasterizations don't belong in git.
/Icon-*.png

# Keylight SDK key and other build-time secrets. Template lives at
# Sources/LutinUI/Secrets.swift.example. dev-app.sh bootstraps a copy
# from the template if missing.
/Sources/LutinUI/Secrets.swift

# Dogfood DMG config — contains your personal signing identity and
# notary profile name. Template at Apps/LutinApp/lutin.yml.example;
# release-app.sh bootstraps a copy from the template if missing.
/Apps/LutinApp/lutin.yml
