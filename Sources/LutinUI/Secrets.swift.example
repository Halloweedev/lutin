import Foundation

/// Template for `Sources/LutinUI/Secrets.swift`, which is gitignored.
///
/// Per Keylight's threat model (https://docs.keylight.dev/concepts/sdk-key/)
/// the `sdk_live_*` key is recoverable from any shipped binary, but
/// committing it to source control lowers the attack from "reverse-engineer
/// a binary" to "grep a public repo" — so it lives outside git.
///
/// To build Lutin from source:
///
///   cp Sources/LutinUI/Secrets.swift.example Sources/LutinUI/Secrets.swift
///   # then edit Secrets.swift and paste your Keylight SDK key.
///
/// Get an SDK key by signing up at https://keylight.dev — use `sdk_test_*`
/// for development and `sdk_live_*` for shipped builds.
enum LutinSecrets {
    static let keylightSDKKey = "sdk_test_REPLACE_ME"
}
