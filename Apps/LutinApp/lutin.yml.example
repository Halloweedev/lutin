# Dogfood config: this file describes how `lutin` itself packages Lutin.app
# into a DMG. The release-app.sh script feeds this to `lutin build` (or
# `lutin release` for the full signed + notarized + stapled pipeline) after
# LutinAppPackager produces ./build/Lutin.app.
#
# This file is the **template**. On a fresh clone, `scripts/release-app.sh`
# copies it to `Apps/LutinApp/lutin.yml` (gitignored) so you can fill in
# your own signing identity and notary profile without leaking them into
# source control.
#
# IMPORTANT (macOS 14+/26): Finder silently refuses to apply a .DS_Store
# layout (background image, icon positions, iconSize) to any DMG that
# Gatekeeper rejects. The signing + notarization + staple steps below are
# load-bearing for the background decoration to actually render on user
# machines — without them, the DMG still installs fine but opens with a
# plain white background and default-sized icons.
project:
  name: Lutin
  bundleId: com.lutin.app
app:
  path: ./build/Lutin.app
output:
  directory: ../../release
  dmgName: Lutin-${version}.dmg
  volumeName: Lutin
# window.width × window.height is the *content area* (the canvas a background
# fills, not the outer window frame). For a custom background image, export
# it at width*scale × height*scale pixels (default scale = 2 for Retina).
# Lutin grows the outer WindowBounds internally to leave the chrome alone.
# window:
#   width: 680
#   height: 420
background:
  type: solid
  colorA: '#FFFFFF'
  scale: 2
items:
- type: app
  id: app
  x: 180
  y: 220
  label: Lutin
- type: applications
  id: applications
  x: 500
  y: 220
  label: Applications
decorations:
- type: arrow
  from: app
  to: applications
  label: Drag to install
# Replace the identity below with your own "Developer ID Application: …"
# string from `security find-identity -p codesigning`, and the profile with
# the name you used in `lutin notary setup --profile NAME`.
signing:
  enabled: true
  identity: "Developer ID Application: Your Name (TEAMID00)"
  signDmg: true
notarization:
  enabled: true
  profile: lutin-notarize
  staple: true
